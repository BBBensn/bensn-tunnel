services:
  wireguard:
    image: lscr.io/linuxserver/wireguard:latest
    container_name: wireguard-tunnel
    cap_add:
      - NET_ADMIN
      - SYS_MODULE
    environment:
      - PUID=568
      - PGID=568
      - TZ=Europe/Vienna
    volumes:
      - ./config:/config
      - /lib/modules:/lib/modules
    # Host-Networking ist noetig, damit Traffic ueber den Tunnel (10.10.0.2:30013)
    # direkt beim Jellyfin-NodePort auf dem NAS-Host ankommt.
    # Kein "sysctls:" hier -- mit network_mode: host verbietet Docker
    # container-eigene Netzwerk-Sysctls (betraeft sonst den Host direkt).
    network_mode: host
    restart: unless-stopped
